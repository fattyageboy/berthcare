# ============================================================================
# BerthCare Local Development Environment Configuration
# ============================================================================
# Copy this file to .env and update values as needed for your local setup
# DO NOT commit .env file to version control - it contains sensitive data
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=BerthCare
APP_VERSION=1.0.0
APP_PORT=3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------------------------------------------
# Primary PostgreSQL database connection
DATABASE_URL=postgresql://postgres:dev_password_change_in_production@localhost:5432/berthcare_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=berthcare_dev
DB_USER=postgres
DB_PASSWORD=dev_password_change_in_production

# Database Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000

# Database SSL (disabled for local development)
DB_SSL=false

# ----------------------------------------------------------------------------
# Redis Configuration (Caching & Session Store)
# ----------------------------------------------------------------------------
REDIS_URL=redis://:dev_redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password
REDIS_DB=0

# Redis TTL Settings (in seconds)
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=3600

# ----------------------------------------------------------------------------
# File Storage Configuration (MinIO - S3 Compatible)
# ----------------------------------------------------------------------------
# MinIO S3-compatible storage for local development
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_REGION=us-east-1
S3_USE_SSL=false

# S3 Bucket Names
S3_BUCKET_PHOTOS=berthcare-dev-photos
S3_BUCKET_DOCUMENTS=berthcare-dev-documents
S3_BUCKET_SIGNATURES=berthcare-dev-signatures

# File Upload Limits (in MB)
MAX_FILE_SIZE_PHOTO=10
MAX_FILE_SIZE_DOCUMENT=25
MAX_FILE_SIZE_SIGNATURE=5

# ----------------------------------------------------------------------------
# Authentication Configuration (Auth0)
# ----------------------------------------------------------------------------
# Auth0 Development Tenant
# Get these values from your Auth0 dashboard: https://manage.auth0.com/
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://api.berthcare.local
AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
AUTH0_LOGOUT_URL=http://localhost:3000/auth/logout

# JWT Settings
JWT_SECRET=your_jwt_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=24h
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------------
# Session Configuration
# ----------------------------------------------------------------------------
SESSION_SECRET=your_session_secret_key_change_in_production_min_32_chars
SESSION_NAME=berthcare.sid
SESSION_COOKIE_MAX_AGE=86400000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
API_BASE_URL=http://localhost:3000
API_VERSION=v1
API_RATE_LIMIT_WINDOW=15
API_RATE_LIMIT_MAX_REQUESTS=100

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
CORS_CREDENTIALS=true

# ----------------------------------------------------------------------------
# Real-time Communication (WebSocket)
# ----------------------------------------------------------------------------
WEBSOCKET_PORT=3001
WEBSOCKET_PATH=/socket.io
WEBSOCKET_TRANSPORTS=websocket,polling

# ----------------------------------------------------------------------------
# Mobile App Configuration
# ----------------------------------------------------------------------------
MOBILE_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ----------------------------------------------------------------------------
# Email Configuration (Development - Mailhog or similar)
# ----------------------------------------------------------------------------
# For local development, use Mailhog or similar email testing tool
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@berthcare.local
EMAIL_FROM_NAME=BerthCare Development

# ----------------------------------------------------------------------------
# Notification Services (Development)
# ----------------------------------------------------------------------------
# Twilio for SMS (optional - leave empty to skip SMS in development)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=your_expo_access_token

# ----------------------------------------------------------------------------
# Geolocation Services
# ----------------------------------------------------------------------------
# Google Maps API for address validation and geocoding
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Geofencing Settings (in meters)
GEOFENCE_RADIUS=100
GEOFENCE_CHECK_ENABLED=true

# ----------------------------------------------------------------------------
# Offline Sync Configuration
# ----------------------------------------------------------------------------
SYNC_INTERVAL=300000
SYNC_BATCH_SIZE=50
SYNC_RETRY_ATTEMPTS=3
SYNC_CONFLICT_RESOLUTION=server_wins

# ----------------------------------------------------------------------------
# Background Jobs & Queue Configuration
# ----------------------------------------------------------------------------
# Bull/BullMQ for job processing
QUEUE_REDIS_URL=redis://:dev_redis_password@localhost:6379
QUEUE_PREFIX=berthcare:queue
QUEUE_DEFAULT_JOB_OPTIONS={"attempts":3,"backoff":{"type":"exponential","delay":2000}}

# ----------------------------------------------------------------------------
# Monitoring & Observability
# ----------------------------------------------------------------------------
# Application Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=berthcare-api-dev

# Sentry Error Tracking (optional for local development)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
FEATURE_OFFLINE_MODE=true
FEATURE_PHOTO_UPLOAD=true
FEATURE_DIGITAL_SIGNATURE=true
FEATURE_FAMILY_PORTAL=true
FEATURE_REALTIME_SYNC=true
FEATURE_GEOFENCING=true

# ----------------------------------------------------------------------------
# Development Tools
# ----------------------------------------------------------------------------
# Enable development debugging
DEBUG=berthcare:*
VERBOSE_LOGGING=true

# Seed data on startup (only for development)
AUTO_SEED_DATABASE=false

# Enable API documentation
ENABLE_API_DOCS=true
API_DOCS_PATH=/api-docs

# Enable GraphQL Playground
ENABLE_GRAPHQL_PLAYGROUND=true
GRAPHQL_PLAYGROUND_PATH=/graphql

# ----------------------------------------------------------------------------
# Security Settings (Development)
# ----------------------------------------------------------------------------
# CSRF Protection
CSRF_ENABLED=false

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Content Security Policy
CSP_ENABLED=false

# Helmet Security Headers
HELMET_ENABLED=true

# ----------------------------------------------------------------------------
# Database Admin Tools
# ----------------------------------------------------------------------------
# Adminer Web UI: http://localhost:8080
# Default credentials from docker-compose.dev.yml
ADMINER_PORT=8080

# ----------------------------------------------------------------------------
# Redis Admin Tools
# ----------------------------------------------------------------------------
# Redis Commander: http://localhost:8081
REDIS_COMMANDER_PORT=8081

# ----------------------------------------------------------------------------
# MinIO Admin Console
# ----------------------------------------------------------------------------
# MinIO Console: http://localhost:9001
# Username: minioadmin
# Password: minioadmin123
MINIO_CONSOLE_PORT=9001

# ============================================================================
# IMPORTANT NOTES FOR DEVELOPERS
# ============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update Auth0 credentials from your Auth0 dashboard
# 3. Change all passwords and secrets before deploying to any environment
# 4. Never commit .env file to version control
# 5. Use strong, unique passwords for production environments
# 6. Keep this .env.example file updated when adding new variables
# ============================================================================
