# BerthCare Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Option 1: Use DATABASE_URL connection string (recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/berthcare

# Option 2: Use individual database parameters (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=berthcare
DB_USER=postgres
DB_PASSWORD=postgres

# Database Connection Pool Settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=30000
DATABASE_STATEMENT_TIMEOUT=30000

# ============================================================================
# REDIS CONFIGURATION (Caching Layer)
# ============================================================================
# Option 1: Use REDIS_URL connection string (recommended for production)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual Redis parameters (alternative to REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=berthcare:

# Redis TLS (for production)
REDIS_TLS=false

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production (min 32 characters)
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRY=24h

# Auth0 Configuration (optional - if not set, falls back to local authentication)
# To use Auth0, create an application in your Auth0 dashboard and fill in these values:
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# ============================================================================
# MICROSERVICES PORTS
# ============================================================================
USER_SERVICE_PORT=3001
VISIT_SERVICE_PORT=3002
SYNC_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# ============================================================================
# EXTERNAL SERVICES (to be configured as needed)
# ============================================================================
# Email service
# EMAIL_SERVICE_API_KEY=
# EMAIL_FROM=

# SMS/Notification service
# SMS_SERVICE_API_KEY=

# File storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_PHOTOS=berthcare-dev-photos
S3_BUCKET_DOCUMENTS=berthcare-dev-documents
S3_BUCKET_SIGNATURES=berthcare-dev-signatures
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
MAX_FILE_SIZE_MB=10

# S3 Server-Side Encryption (SSE) Configuration
# Enable SSE with customer-managed keys (KMS)
S3_SSE_ENABLED=true
S3_SSE_ALGORITHM=aws:kms
# KMS Key ID for S3 encryption (leave empty for default AWS managed key)
S3_KMS_KEY_ID=
# For development with MinIO, use AES256 instead of KMS
S3_SSE_ALGORITHM_DEV=AES256

# Database Encryption Configuration
# Enable encryption for sensitive metadata fields
DB_ENCRYPTION_ENABLED=true
# Encryption key for database field-level encryption (32-byte hex string)
# IMPORTANT: Generate a secure random key in production
DB_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google Maps Platform (for location verification)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Firebase Cloud Messaging (FCM) for Push Notifications
# Service account key JSON (paste entire JSON as single line)
# Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FCM_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ============================================================================
# MONITORING & OBSERVABILITY (optional)
# ============================================================================
# APM_SERVICE_NAME=berthcare-backend
# APM_SERVER_URL=
# SENTRY_DSN=
