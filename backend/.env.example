# BerthCare Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Option 1: Use DATABASE_URL connection string (recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/berthcare

# Option 2: Use individual database parameters (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=berthcare
DB_USER=postgres
DB_PASSWORD=postgres

# Database Connection Pool Settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=30000
DATABASE_STATEMENT_TIMEOUT=30000

# ============================================================================
# REDIS CONFIGURATION (Caching Layer)
# ============================================================================
# Option 1: Use REDIS_URL connection string (recommended for production)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual Redis parameters (alternative to REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=berthcare:

# Redis TLS (for production)
REDIS_TLS=false

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRY=24h

# ============================================================================
# MICROSERVICES PORTS
# ============================================================================
USER_SERVICE_PORT=3001
VISIT_SERVICE_PORT=3002
SYNC_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# ============================================================================
# EXTERNAL SERVICES (to be configured as needed)
# ============================================================================
# Email service
# EMAIL_SERVICE_API_KEY=
# EMAIL_FROM=

# SMS/Notification service
# SMS_SERVICE_API_KEY=

# File storage
# STORAGE_BUCKET=
# STORAGE_REGION=

# ============================================================================
# MONITORING & OBSERVABILITY (optional)
# ============================================================================
# APM_SERVICE_NAME=berthcare-backend
# APM_SERVER_URL=
# SENTRY_DSN=
